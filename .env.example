# Used by the Docker path (docker compose reads .env automatically). The native
# path (scripts/run-native.sh, via ../start.sh) reads the same var names from
# the environment — see gateway/README.md.

# Hostname nginx answers on (TLS SNI / redirect host).
SERVER_NAME=localhost

# Listen ports. Native nginx defaults to 8080/8443 (no sudo). The Docker path
# publishes these on the host and proxies to 80/443 inside the container.
HTTP_PORT=8080
HTTPS_PORT=8443

# Where to find the upstream apps. Native: 127.0.0.1:<port>. Docker: point at
# host.docker.internal:<port> so the container can reach host-run apps.
WEB_UPSTREAM=127.0.0.1:3100
RATCHET_UPSTREAM=127.0.0.1:3000
